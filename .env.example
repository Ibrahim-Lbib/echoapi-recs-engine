# Database
# Use postgresql+asyncpg://user:password@localhost:5432/echoapi for local dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recommendation_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Security
# Required for /api/v1/train/ endpoint
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here

# App Settings
PROJECT_NAME="Recommendation API"
API_V1_STR="/api/v1"
APP_ENV=development
DEBUG=False
ACCESS_TOKEN_EXPIRE_MINUTES=11520
ALGORITHM=HS256
